# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dados persistidos localmente (gerados em runtime)
/data/*.json

# uploads de usuário (binários locais)
/public/uploads/*.jpg
/public/uploads/*.jpeg
/public/uploads/*.png
/public/uploads/*.webp
/public/uploads/*.gif

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

.vercel

# claude local settings
.claude/launch.json
.claude/settings.local.json

.vercel
.env*
